  "keyFeatures": [
    "Self-hosted game platform with full user management",
    "Built-in economy system with virtual currency and transactions",
    "Asset catalog with rendering and thumbnail generation",
    "Game hosting with self-hosted and dedicated server options",
    "Roblox client integration for classic gameplay",
    "Admin panel for moderation and platform management",
    "Character customization and avatar system",
    "Groups, forums, and social features"
  ],
  "publicApiSurface": [
    "GET /balance/{id} - Get user balance",
    "POST /transact - Transfer currency between users",
    "POST /mint - Create new currency",
    "POST /burn - Remove currency from circulation",
    "POST /stipend/{id} - Issue daily stipend",
    "GET /transactions/{id} - Get user transaction history",
    "GET /api/avatar - Avatar rendering API",
    "GET /api/clientappsettings - Client application settings",
    "GET /api/clientsharedsettings - Client shared settings",
    "POST /api/render - Asset rendering queue",
    "mercury.core.ts Config - Platform configuration schema"
  ]
